    <!-- Wheels-->

    <!-- Fake wheels to emulate track motion -->
    <link name='left_track_front_wheel0'>
        <inertial>
            <mass value="0.5" />
            <origin xyz="0 0 0" />
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
        </inertial>

        <collision name='left_track_front_wheel0_collision'>
            <geometry>
                <cylinder length="0.15" radius="0.12" />
            </geometry>
            <surface>
                <!-- This friction pamareters don't contain reliable data!! -->
                <friction>
                    <ode>
                        <mu>1</mu>
                        <mu2>1</mu2>
                        <fdir1>0 0 0</fdir1>
                        <slip1>0.0</slip1>
                        <slip2>0.0</slip2>
                    </ode>
                </friction>
                <contact>
                    <ode>
                        <soft_cfm>0</soft_cfm>
                        <soft_erp>0.2</soft_erp>
                        <kp>1e+6</kp>
                        <kd>1</kd>
                        <max_vel>0.01</max_vel>
                        <min_depth>0.001</min_depth>
                    </ode>
                </contact>
            </surface>
        </collision>

        <visual name='left_track_front_wheel0_visual'>
            <material name="clear_color">
                <color rgba="0.0 0.0 0.0 0.0" />
            </material>
            <geometry>
                <cylinder length="0.15" radius="0.12" />
            </geometry>
        </visual>
    </link>
    <joint name='left_track_front_wheel0_j' type='continuous'>
