<?xml version="1.0"?>
<robot name="scout_mini" xmlns:xacro="http://ros.org/wiki/xacro">
    <!-- Vehicle Geometries -->

    <!-- 바닥 기준 프레임 -->
    <link name="base_footprint" />
    <!-- base_footprint -> base_link 고정 변환 -->
    <joint name="base_footprint_to_base_link" type="fixed">
        <!-- 휠 중심이 지면에서 0.08m가 되도록: z = 0.18m (휠 중심 z = -0.10m) -->
        <origin xyz="0 0 0.18" rpy="0 0 0" />
        <parent link="base_footprint" />
        <child link="base_link" />
    </joint>

    <!-- Base link -->
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.57 0 -1.57" />
            <geometry>
                <mesh filename="package://scout_description/meshes/mini_body.dae" />
            </geometry>
        </visual>

        <!-- Meshlab 기준 scout_mini_base_link.dae Bounding Box
             Size: 0.389876 0.182181 0.560607 (X Y Z)
             -> 동일 축 기준 box collision으로 근사 -->
        <collision>
            <origin xyz="0 0 0.015" rpy="1.57 0 -1.57" />
            <geometry>
                <box size="0.389876 0.182181 0.560607" />
            </geometry>
        </collision>
    </link>

    <!-- 차체 관성 링크 (총 질량 23kg 중 19kg) -->
    <link name="inertial_link">
        <inertial>
            <mass value="19.0" />
            <!-- 질량중심을 base_link 원점과 일치시킴 -->
            <origin xyz="0 0 0" />
            <!-- 0.612 x 0.580 x 0.245 m, m=19kg 직육면체 근사 관성 -->
            <inertia
                ixx="0.627673"
                ixy="0.0"
                ixz="0.0"
                iyy="0.688068"
                iyz="0.0"
                izz="1.125661" />
        </inertial>
    </link>

    <joint name="inertial_joint" type="fixed">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <parent link="base_link" />
        <child link="inertial_link" />
    </joint>

    <!-- ======================= Scout wheels ======================= -->
    <!-- Meshlab 기준 wheel.dae Bounding Box:
         Size: 0.159896 0.159953 0.132000
         -> 지름 ≈ 0.16m (반지름 ≈ 0.08m), 두께 ≈ 0.132m
         -> cylinder(radius=0.08, length=0.132)로 근사 -->

    <!-- Front Right Wheel -->
    <link name="front_right_wheel_link">
        <inertial>
            <mass value="1.0" />
            <origin xyz="0 0 0" />
            <inertia
                ixx="0.002013"
                ixy="0.0"
                ixz="0.0"
                iyy="0.002013"
                iyz="0.0"
                izz="0.002685" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://scout_description/meshes/wheel.dae" />
            </geometry>
        </visual>
        <collision>
            <!-- 좌우 방향으로 1.5cm 바깥으로 이동 (joint의 Rx 때문에 base y로 투영됨) -->
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://scout_description/meshes/wheel.dae" />
            </geometry>
        </collision>
    </link>

    <joint name="front_right_wheel" type="continuous">
        <origin xyz="0.2255 -0.210 -0.10" rpy="1.57 0 0" />
        <parent link="base_link" />
        <child link="front_right_wheel_link" />
        <axis xyz="0 0 -1" rpy="0 0 0" />
    </joint>

    <!-- Front Left Wheel -->
    <link name="front_left_wheel_link">
        <inertial>
            <mass value="1.0" />
            <origin xyz="0 0 0" />
            <inertia
                ixx="0.002013"
                ixy="0.0"
                ixz="0.0"
                iyy="0.002013"
                iyz="0.0"
                izz="0.002685" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://scout_description/meshes/wheel.dae" />
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://scout_description/meshes/wheel.dae" />
            </geometry>
        </collision>
    </link>

    <joint name="front_left_wheel" type="continuous">
        <origin xyz="0.2255 0.210 -0.10" rpy="-1.57 0 0" />
        <parent link="base_link" />
        <child link="front_left_wheel_link" />
        <axis xyz="0 0 1" rpy="0 0 0" />
    </joint>

    <!-- Rear Right Wheel -->
    <link name="rear_right_wheel_link">
        <inertial>
            <mass value="1.0" />
            <origin xyz="0 0 0" />
            <inertia
                ixx="0.002013"
                ixy="0.0"
                ixz="0.0"
                iyy="0.002013"
                iyz="0.0"
                izz="0.002685" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://scout_description/meshes/wheel.dae" />
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://scout_description/meshes/wheel.dae" />
            </geometry>
        </collision>
    </link>

    <joint name="rear_right_wheel" type="continuous">
        <origin xyz="-0.2255 -0.210 -0.10" rpy="1.57 0 0" />
        <parent link="base_link" />
        <child link="rear_right_wheel_link" />
        <axis xyz="0 0 -1" rpy="0 0 0" />
    </joint>

    <!-- Rear Left Wheel -->
    <link name="rear_left_wheel_link">
        <inertial>
            <mass value="1.0" />
            <origin xyz="0 0 0" />
            <inertia
                ixx="0.002013"
                ixy="0.0"
                ixz="0.0"
                iyy="0.002013"
                iyz="0.0"
                izz="0.002685" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://scout_description/meshes/wheel.dae" />
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://scout_description/meshes/wheel.dae" />
            </geometry>
        </collision>
    </link>

    <joint name="rear_left_wheel" type="continuous">
        <origin xyz="-0.2255 0.210 -0.10" rpy="-1.57 0 0" />
        <parent link="base_link" />
        <child link="rear_left_wheel_link" />
        <axis xyz="0 0 1" rpy="0 0 0" />
    </joint>

    <!-- ===================== Scout gazebo plugin ===================== -->
    <gazebo>
        <!-- Joint states -->
        <plugin
            filename="libignition-gazebo-joint-state-publisher-system.so"
            name="ignition::gazebo::systems::JointStatePublisher">
            <topic>joint_states</topic>
            <update_rate>50</update_rate>
            <joint_name>front_right_wheel</joint_name>
            <joint_name>front_left_wheel</joint_name>
            <joint_name>rear_right_wheel</joint_name>
            <joint_name>rear_left_wheel</joint_name>
        </plugin>

        <!-- Skid-steer DiffDrive -->
        <plugin
            filename="libignition-gazebo-diff-drive-system.so"
            name="ignition::gazebo::systems::DiffDrive">
        
            <left_joint>front_left_wheel</left_joint>
            <left_joint>rear_left_wheel</left_joint>
            <right_joint>front_right_wheel</right_joint>
            <right_joint>rear_right_wheel</right_joint>
        
            <wheel_separation>0.490</wheel_separation>
            <wheel_radius>0.080</wheel_radius>
        
            <!-- torque는 그대로 두고, 속도/가속도 제한을 v2와 비슷하게 맞춤 -->
            <max_wheel_torque>20</max_wheel_torque>
        
            <max_linear_acceleration>2.0</max_linear_acceleration>
            <min_linear_acceleration>-2.0</min_linear_acceleration>
            <max_angular_acceleration>1.0</max_angular_acceleration>
            <min_angular_acceleration>-1.0</min_angular_acceleration>
        
            <max_linear_velocity>10.0</max_linear_velocity>
            <min_linear_velocity>-10.0</min_linear_velocity>
            <max_angular_velocity>1.0</max_angular_velocity>
            <min_angular_velocity>-1.0</min_angular_velocity>
        
            <topic>cmd_vel</topic>
            <odom_topic>odom</odom_topic>
            <tf_topic>tf</tf_topic>
            <odom_publish_frequency>50</odom_publish_frequency>
        
            <frame_id>odom</frame_id>
            <child_frame_id>base_footprint</child_frame_id>
        </plugin>

    </gazebo>

</robot>
